generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Client {
  id               String  @id @default(cuid())
  email            String  @unique
  contactName      String?
  preferredName    String? // what the client wants the agent to call them (e.g. "Kyle" even if contactName is "Kyle Kufuor")
  businessName     String
  industry         String
  businessGoal     String
  website          String?
  brandVoice       String  @db.Text
  preferredChannel String
  whatsappNumber   String?

  onboardingCompletedAt DateTime?
  northStarMetric       String?
  agentGoal             String?   @db.Text
  createdAt             DateTime  @default(now())

  stripeCustomerId String    @unique
  billingEmail     String
  billingStatus    String    @default("active")
  pausedAt         DateTime?
  cancelledAt      DateTime?

  // Overage billing — when true, agent keeps working past interactionLimit and
  // we charge overageRateCents per extra interaction at end of month. When
  // false (default), agent hard-stops at the limit.
  overageEnabled   Boolean @default(false)
  overageRateCents Int     @default(10) // 10¢/interaction by default ($0.05-0.10 range)

  // 1Password vault UUID scoped to this client. Set by Kyle during onboarding
  // (white-glove, matches the Zoom co-setup). When non-null, the resolveSecret
  // helper validates that any op:// ref's vault matches this UUID before
  // calling 1Password, preventing cross-tenant secret access. Null = no
  // vault yet; any browser task referencing {{secret:op://...}} will fail
  // until Kyle provisions one.
  onepasswordVaultId String?

  agents                 Agent[]
  tasks                  Task[]
  recommendations        Recommendation[]
  outcomes               Outcome[]
  credentials            Credential[]
  conversationMessages   ConversationMessage[]
  suppressions           Suppression[]
  overageEvents          OverageEvent[]
  scheduledEmails        ScheduledEmail[]
  emailSends             EmailSend[]
  toolRequests           ToolRequest[]
  toolConnectionRequests ToolConnectionRequest[]
  browserSessions        BrowserSession[]
  credentialAccesses     CredentialAccess[]
  prospectsConvertedFrom Prospect[]
  leads                  Lead[]
  clientDevices          ClientDevice[]
  localTasks             LocalTask[]

  @@index([stripeCustomerId])
  @@index([billingStatus])
}

model Agent {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  name        String
  email       String @unique
  personality String @db.Text
  purpose     String @db.Text
  agentType   String

  // Platform-level flag — when true, this agent accepts emails from any active
  // Prospect (not just its owner client). Used for Atlas-style onboarding
  // agents that need to talk to non-clients. See inbound webhook auth in
  // oracle/index.ts.
  acceptFromProspects Boolean @default(false)

  tools             String[]
  schedule          String
  autonomyLevel     String    @default("supervised") // "supervised" | "autonomous" — supervised is default (plan-then-approve); client toggles to autonomous once they trust the agent. Legacy values "advisory" / "copilot" are migrated on-read in scaffold.ts.
  timezone          String    @default("America/New_York") // IANA tz — governs cron firing + polite hours
  deliveryFormat    String    @default("email_summary") // "email_summary" | "email_with_attachments" | "email_plus_sheet"
  tone              String    @default("conversational") // "formal" | "conversational" | "brief" — client-configurable voice register
  emailFrequency    String    @default("immediate") // "immediate" | "daily_digest" | "weekly_digest" — when non-immediate, runs queue to ScheduledEmail (kind="digest_pending") and the hourly processDueDigests cron rolls them up
  // Digest cadence (ignored when emailFrequency="immediate"). Client-configurable via portal; defaults are 8am agent-timezone / Monday.
  digestHour        Int       @default(8) // 0-23 in agent timezone
  digestDayOfWeek   Int       @default(1) // 0=Sun..6=Sat, used only for weekly_digest
  lastDigestSentAt  DateTime? // prevents double-send within a period
  clientNorthStar   String?
  // One friendly, client-facing sentence shown in the portal in place of the
  // internal system prompt (personality/purpose). Clients should NEVER see the
  // raw prompt. Atlas sets this on build; falls back to a generic line if null.
  clientDescription String?

  // Client-configurable operating limits (portal Configure page). Both are
  // injected into the agent's system prompt by prompt-assembler so the agent
  // genuinely obeys them — null/[] means "no explicit limit, use judgement".
  maxEmailsPerDay Int? // soft cap on outreach emails the agent sends per working day
  followUpDays    Int[] @default([]) // e.g. [3, 7] — days after first contact to nudge non-responders
  // Non-Composio "custom" tools (CoStar, Crexi, etc.) the agent reaches via
  // the browse tool, using credentials the client stores in 1Password.
  // Surfaced on the portal Tools page as secure credential-entry rows.
  // Shape: [{ name, source, siteUrl, fields: [{ title, fieldType }] }].
  customTools     Json?

  // Client-facing "Things you can ask {agent}" examples shown in the portal next
  // to the agent's inbox address. AI-generated per agent (grounded in purpose +
  // tools), lazily on first portal load, then cached here. Shape:
  // [{ capability, subject, body }]. Null = not generated yet. See
  // oracle/example-emails.ts + GET /agents/:id/example-emails.
  exampleEmails            Json?
  exampleEmailsGeneratedAt DateTime?

  // Per-agent Communication Settings — a routing-preference layer that does NOT
  // store channel credentials, only which channel plays each role. Roles:
  //   inbound.allowedSenders — extra emails allowed to reach the agent + get a
  //     reply (extends the owner-client check in checkInboundAuth)
  //   mfaRelay  — how the agent asks the human for a verification code
  //   outbound  — which identity the agent sends client-facing comms from
  // Null (or a null role) = today's default behavior. Shape + safe parser live
  // in shared/communication-settings.ts (Zod). Channels are drawn from platform
  // natives (Client.whatsappNumber / Client.email) + channelType-tagged connected
  // tools (shared/mcp/channel-types.ts).
  communicationSettings Json?

  primaryModel   String @default("claude-sonnet-4-6")
  analyticsModel String @default("gemini")
  creativeModel  String @default("gpt-4o")

  // Lifecycle: pending_approval → building → active → paused / killed.
  // - pending_approval: created, awaiting operator decision
  // - building: operator-approved internally for build/QA; not client-facing yet
  // - active: live for the client; scheduled runs fire; real side-effects send
  // - paused: held; resumable
  // - killed: terminated
  status           String    @default("pending_approval")
  approvedAt       DateTime?
  lastRunAt        DateTime?
  runningSince     DateTime? // set when a run starts, cleared when it ends — drives the portal "working now" badge
  nextScheduledRun DateTime?

  // Control-plane pause metadata (who paused + why), so resume-authority can be
  // enforced: a client may resume a client-initiated pause, but a system pause
  // (a tripped seatbelt / runaway loop) or an operator pause is operator-only.
  //   pausedBy: "client" | "operator" | "system" | null (not paused)
  pausedBy     String?
  pausedReason String?   @db.Text
  pausedAt     DateTime?

  // Dry-run mode — when true, side-effect callsites (sendEmail, sendWhatsApp,
  // Composio executeTool, browse actions that write) record what they WOULD
  // have done to DryRunLog instead of actually firing. Defaults true for new
  // "building" agents and false for active. Operators can override either
  // way for one-off testing.
  dryRun Boolean @default(false)

  stripeSubscriptionId String?
  setupFeeInvoiceId    String?
  monthlyRetainerCents Int
  setupFeeCents        Int
  historyTier          String  @default("standard")

  // Pricing tier
  pricingTier String @default("starter") // "starter" | "growth" | "scale" | "enterprise"

  // Interaction tracking
  interactionCount   Int       @default(0) // current billing cycle
  interactionLimit   Int       @default(1000) // per tier: 1000/3000/-1(unlimited)
  overageCount       Int       @default(0) // extra interactions past the limit (only if client opted into overage)
  interactionResetAt DateTime? // next reset date (monthly)

  // Budget enforcement
  budgetMonthlyCents Int       @default(5000) // $50 default
  budgetWarningAt    DateTime? // when 80% threshold was hit
  budgetPausedAt     DateTime? // when 100% threshold paused the agent

  clientMemoryObject String    @db.Text
  lastMemoryUpdateAt DateTime?

  totalTasksCompleted  Int   @default(0)
  totalRecommendations Int   @default(0)
  approvalRate         Float @default(0)
  implementationRate   Float @default(0)

  tasks                  Task[]
  recommendations        Recommendation[]
  outcomes               Outcome[]
  conversationMessages   ConversationMessage[]
  performanceSignals     PerformanceSignal[]
  apiUsage               ApiUsage[]
  dryRunLogs             DryRunLog[]
  suppressions           Suppression[]
  overageEvents          OverageEvent[]
  scheduledEmails        ScheduledEmail[]
  emailSends             EmailSend[]
  toolRequests           ToolRequest[]
  toolConnectionRequests ToolConnectionRequest[]
  browserSessions        BrowserSession[]
  credentialAccesses     CredentialAccess[]
  builds                 Build[]
  improvements           AgentImprovement[]
  leads                  Lead[]
  localTasks             LocalTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([clientId, agentType])
  @@index([status])
  @@index([agentType])
}

model Task {
  id       String @id @default(cuid())
  agentId  String
  agent    Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  taskType    String
  description String @db.Text

  status       String    @default("pending")
  executedAt   DateTime?
  completedAt  DateTime?
  errorMessage String?   @db.Text
  retryCount   Int       @default(0)

  rawOutput      String    @db.Text
  emailSentAt    DateTime?
  whatsappSentAt DateTime?

  recommendations Recommendation[]

  createdAt DateTime @default(now())

  @@index([agentId])
  @@index([clientId])
  @@index([status])
  @@index([taskType])
}

model Recommendation {
  id       String  @id @default(cuid())
  agentId  String
  agent    Agent   @relation(fields: [agentId], references: [id], onDelete: Cascade)
  clientId String
  client   Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  taskId   String?
  task     Task?   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  title       String
  description String   @db.Text
  actionItems String[]
  reasoning   String?  @db.Text

  expectedMetric    String
  baselineValue     Float
  expectedDirection String
  expectedChangePct Float?

  implementationMode   String  @default("advisory")
  autonomouslyExecuted Boolean @default(false)
  autonomousActionLog  String? @db.Text

  // Email template context
  emailType       String?
  approveActionId String? @unique
  status          String  @default("pending")

  clientAction   String    @default("pending")
  clientActionAt DateTime?
  clientNotes    String?   @db.Text

  verificationScheduled DateTime?
  verifiedAt            DateTime?
  verificationMethod    String?
  verificationResult    Boolean?
  verificationNotes     String?   @db.Text

  resolvedAt DateTime?

  outcomes Outcome[]

  sentAt DateTime @default(now())

  @@index([agentId])
  @@index([clientId])
  @@index([clientAction])
  @@index([expectedMetric])
  @@index([implementationMode])
  @@index([approveActionId])
  @@index([status])
}

model Outcome {
  id               String         @id @default(cuid())
  agentId          String
  agent            Agent          @relation(fields: [agentId], references: [id], onDelete: Cascade)
  clientId         String
  client           Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  recommendationId String
  recommendation   Recommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)

  metric        String
  baselineValue Float
  measuredValue Float
  changeAmount  Float
  changePercent Float

  measuredAt        DateTime
  measurementWindow String
  measurementMethod String
  toolUsed          String?
  rawData           String?  @db.Text

  confidenceLevel        String  @default("medium")
  implementationVerified Boolean @default(false)
  notes                  String? @db.Text

  createdAt DateTime @default(now())

  @@index([recommendationId])
  @@index([metric])
  @@index([measurementWindow])
  @@index([agentId])
  @@index([clientId])
}

model ConversationMessage {
  id       String @id @default(cuid())
  agentId  String
  agent    Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  role    String
  content String @db.Text
  channel String

  threadId  String
  inReplyTo String?

  archivedAt DateTime?

  createdAt DateTime @default(now())

  @@index([agentId])
  @@index([clientId])
  @@index([threadId])
  @@index([archivedAt])
}

model PerformanceSignal {
  id      String @id @default(cuid())
  agentId String
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  signalType    String
  outputSummary String @db.Text
  clientAction  String @db.Text

  agentType  String
  anonymized Boolean @default(true)

  createdAt DateTime @default(now())

  @@index([agentId])
  @@index([agentType])
  @@index([signalType])
}

model Credential {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  toolName     String
  oauthToken   String?   @db.Text
  apiKey       String?   @db.Text
  refreshToken String?   @db.Text
  expiresAt    DateTime?
  // Encrypted JSON of custom-tool field values (username/password/etc) for
  // clients without a 1Password vault. AES-256-GCM via shared/encryption.ts.
  secretsEncrypted String? @db.Text
  // Outcome of the agent's last browser login with these creds: "ok" | "failed".
  lastUseStatus String?
  lastUseError  String? @db.Text

  connectedAt DateTime  @default(now())
  lastUsedAt  DateTime?
  status      String    @default("active")

  @@unique([clientId, toolName])
  @@index([clientId])
  @@index([status])
}

model ApiUsage {
  id      String @id @default(cuid())
  agentId String
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  model               String
  inputTokens         Int // uncached input tokens only
  outputTokens        Int
  totalTokens         Int
  cacheCreationTokens Int     @default(0) // billed at 1.25× base input rate
  cacheReadTokens     Int     @default(0) // billed at 0.10× base input rate
  toolErrorCount      Int     @default(0) // failed tool calls during this run — used for agent error rate
  isPrimaryRun        Boolean @default(true) // false on secondary rows from multi-model runs (e.g. Haiku row when Sonnet also wrote) so run-level counts don't double
  costInCents         Int // authoritative — computed at write time

  taskType String
  taskId   String?

  createdAt DateTime @default(now())

  @@index([agentId])
  @@index([model])
  @@index([createdAt])
}

model OverageEvent {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  agentId  String
  agent    Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  unitCostCents     Int // snapshot of overageRateCents at time of event
  billingCycleMonth String // "YYYY-MM" for end-of-month aggregation
  invoicedAt        DateTime? // when this was rolled up into a Stripe invoice
  createdAt         DateTime  @default(now())

  @@index([clientId, billingCycleMonth])
  @@index([agentId])
  @@index([invoicedAt])
}

// ScheduledEmail — onboarding-checkpoint emails enqueued on agent approval
// (T+3 check-in, T+7 capability highlight, T+14 feedback + 2nd-agent pitch).
// A daily cron in oracle/scheduler.ts picks up rows where status=pending and
// scheduledAt <= now() and fires them through the email router.
model ScheduledEmail {
  id       String @id @default(cuid())
  agentId  String
  agent    Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  kind         String // "checkin_3day" | "highlight_7day" | "feedback_14day" | "digest_pending" | "digest"
  scheduledAt  DateTime
  status       String    @default("pending") // pending | sent | cancelled | failed
  sentAt       DateTime?
  errorMessage String?   @db.Text

  // Used by kind="digest_pending": JSON snapshot of one queued run
  // ({ response, toolsUsed, attachmentMeta, recommendations, ranAt }). Rolled up
  // by processDueDigests cron into a single kind="digest" email. Null for
  // checkpoint rows.
  payload String? @db.Text

  createdAt DateTime @default(now())

  @@index([status, scheduledAt])
  @@index([agentId])
  @@index([clientId])
  @@index([agentId, kind, status])
}

// EmailSend — audit trail for every outbound email via shared/email.ts.
//
// Each row is created the moment Resend's API returns a message id (status
// "accepted"). The /webhooks/email-events endpoint then updates the row when
// Resend pushes lifecycle events (sent → delivered → bounced/complained).
//
// This is how we close the silent-failure loop: instead of "we called sendEmail
// and assumed it landed", every artifact (proposal, quote, agent_response, ops
// notification) has a queryable delivery status. Bounces fire WhatsApp alerts.
model EmailSend {
  id String @id @default(cuid())

  // Who sent it
  agentId    String
  agent      Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  // Optional links — emails to prospects don't have a Client yet; ops emails
  // to OPERATOR_EMAIL have no Client OR Prospect linkage.
  clientId   String?
  client     Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  prospectId String?
  prospect   Prospect? @relation(fields: [prospectId], references: [id], onDelete: SetNull)

  // Where it went
  to        String
  subject   String // @db.Text intentionally NOT used — subjects are short and we want index-friendly
  // Optional categorization for filtering/dashboards. Free-form string from the
  // sendEmail call site, e.g. "proposal_teaser" | "quote_teaser" |
  // "agent_response" | "ops_notification" | "thanks_email".
  emailType String?

  // Resend tracking. Unique so /webhooks/email-events can look up by the id
  // Resend sends in its payload. Nullable on the off chance Resend ever returns
  // accept-without-id (shouldn't happen but the type allows it).
  resendMessageId String? @unique

  // Lifecycle status. Progresses one-way; webhook handler only forwards.
  //   accepted          — Resend's API returned a message id (default after send)
  //   sent              — Resend webhook confirms accepted-then-handed-to-MTA
  //   delivered         — recipient mailbox accepted it
  //   bounced           — hard or soft bounce (terminal)
  //   complained        — recipient marked as spam (terminal)
  //   delivery_delayed  — temporary delay, Resend still retrying
  //   dropped           — Resend dropped before send (suppression list etc, terminal)
  status       String  @default("accepted")
  bounceReason String? @db.Text

  // Per-state timestamps. acceptedAt always set; rest filled by webhook.
  acceptedAt   DateTime  @default(now())
  sentAt       DateTime?
  deliveredAt  DateTime?
  bouncedAt    DateTime?
  complainedAt DateTime?
  delayedAt    DateTime?

  @@index([agentId])
  @@index([prospectId])
  @@index([clientId])
  @@index([resendMessageId])
  @@index([status, acceptedAt])
  @@index([to])
}

model StripeEvent {
  id          String    @id
  type        String
  data        String    @db.Text
  processed   Boolean   @default(false)
  processedAt DateTime?

  createdAt DateTime @default(now())

  @@index([type])
  @@index([processed])
}

// DryRunLog — captures the side-effects an agent WOULD have performed when
// Agent.dryRun is true. Runtime intercept points (sendEmail, sendWhatsApp,
// Composio executeTool, browse actions) write to this table instead of
// actually firing. Operators inspect these rows to validate agent behavior
// before flipping the agent to dryRun=false + status="active".
//
// kind values:
//   "email"     — captured a sendEmail call (payload has to/subject/html)
//   "whatsapp"  — captured a WhatsApp send (payload has to/message)
//   "composio"  — captured a Composio tool execution (payload has tool/params)
//   "browse"    — captured a Stagehand browse action (payload has goal/url)
//   "other"     — anything else we add a hook for later
model DryRunLog {
  id      String @id @default(cuid())
  agentId String
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  kind    String // see comment above
  // What the agent was trying to do — varies by kind, stored as a JSON blob.
  // For "email": { to, subject, html, replyTo, ... }
  // For "composio": { toolName, params }
  // etc. Read by the operator UI to render appropriate previews.
  payload Json

  // Free-text label for grouping multiple captures from a single run
  // ("scenario X attempt 1", "morning source pass dry-run 2026-06-04", etc).
  // Set by the run trigger; null when the agent ran from a real trigger that
  // happened to be in dry-run mode.
  scenario String?

  // Whether the operator has reviewed + approved this captured side-effect.
  // null until reviewed; true if approved (would've been fine to send live);
  // false if rejected (operator caught a problem before going live).
  reviewedAt DateTime?
  reviewedOk Boolean?
  reviewNote String?   @db.Text

  capturedAt DateTime @default(now())

  @@index([agentId])
  @@index([agentId, capturedAt])
  @@index([scenario])
}

model Suppression {
  id       String @id @default(cuid())
  agentId  String
  agent    Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // What was suppressed
  findingKey         String // e.g. "activation_broken", "low_traffic", "signup_drop"
  findingDescription String @db.Text
  metricName         String // the metric this finding relates to
  metricValueAtSend  Float // the value when the finding was last sent

  // When to unsuppress
  cooldownDays       Int   @default(7) // minimum days before resending
  changeThresholdPct Float @default(10) // resend if metric changes by this %

  // Tracking
  lastSentAt    DateTime
  suppressUntil DateTime // computed: lastSentAt + cooldownDays
  sendCount     Int      @default(1) // how many times this finding has been sent

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([agentId, clientId, findingKey])
  @@index([agentId])
  @@index([clientId])
  @@index([suppressUntil])
}

// ToolRequest — client asks for a tool that isn't in Composio's OAuth catalog.
// Submitted from the portal's agent detail page. Kyle gets a WhatsApp ping on
// every new row; he resolves manually (white-glove path). Lean by design — no
// URL or category fields; Kyle asks for more context in the follow-up.
model ToolRequest {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  agentId  String
  agent    Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  toolName String
  reason   String @db.Text

  status       String    @default("pending") // "pending" | "resolved" | "dismissed"
  resolvedAt   DateTime?
  resolvedNote String?   @db.Text

  createdAt DateTime @default(now())

  @@index([clientId, status])
  @@index([agentId])
  @@index([createdAt])
}

// ToolConnectionRequest — agent realized mid-run it needs an OAuth tool it
// doesn't have, invoked the request_tool_connection platform tool, and we've
// emailed the client a Composio OAuth link. Distinct from ToolRequest (which
// is the portal white-glove path fulfilled by Kyle). De-dup window: don't
// re-email the same (clientId, appName) if an open row exists from the last
// 24h — see shared/runtime/tools/request-tool-connection.ts.
model ToolConnectionRequest {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  agentId  String
  agent    Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  appName String // Composio app slug, e.g. "gmail", "googlecalendar"
  reason  String @db.Text // agent-authored explanation of why it needs this, surfaced in the email

  composioConnectionId String? // returned by initiateOAuthConnection(); null until we've called Composio
  redirectUrl          String? @db.Text // the OAuth URL the client clicks; null until emailed

  status      String    @default("pending") // "pending" | "emailed" | "connected" | "expired" | "declined"
  emailSentAt DateTime?
  connectedAt DateTime?

  createdAt DateTime @default(now())

  @@index([clientId, appName, status])
  @@index([agentId])
  @@index([composioConnectionId])
  @@index([createdAt])
}

// BrowserSession — audit trail for one Stagehand/Browserbase session run by
// the `browse` platform tool. Written on open, updated on close. Transcript
// is a short summary of what Claude saw/did (not the full page HTML). Use
// for debugging + cost visibility. browserbaseSessionId lets us jump to the
// Browserbase dashboard for the same session when triaging a failure.
model BrowserSession {
  id       String @id @default(cuid())
  agentId  String
  agent    Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  goal                 String  @db.Text
  startingUrl          String?
  browserbaseSessionId String? // set once the session starts

  startedAt  DateTime  @default(now())
  endedAt    DateTime?
  durationMs Int?

  status        String  @default("running") // "running" | "success" | "failed" | "timeout"
  resultSummary String? @db.Text // short summary of what the agent did / extracted
  errorMessage  String? @db.Text

  @@index([agentId, startedAt])
  @@index([clientId, startedAt])
  @@index([status])
  @@index([browserbaseSessionId])
}

// CredentialAccess — audit row written every time resolveSecret() returns a
// value to a caller. Powers the per-row "last accessed Apr 22" audit trail
// on the portal Tools page and underwrites the trust contract ("we can
// only ask 1Password to use them; here's exactly when we did"). NEVER
// stores the secret value itself — only metadata.
model CredentialAccess {
  id       String  @id @default(cuid())
  clientId String
  client   Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  agentId  String?
  agent    Agent?  @relation(fields: [agentId], references: [id], onDelete: SetNull)

  vaultName String // Client.onepasswordVaultId at time of access
  itemTitle String // 1P item title (e.g. "LinkedIn")
  field     String // field name within the item (e.g. "password")

  accessedAt DateTime @default(now())

  @@index([clientId, vaultName, itemTitle, accessedAt])
  @@index([agentId, accessedAt])
  @@index([accessedAt])
}

// Prospect — a lead going through the onboarding flow with Atlas. Lives
// separately from Client until the deal closes (quote accepted + paid), at
// which point a Client row is created and Prospect.convertedClientId is set.
// All intake state (form answers, SOPs, chat with Atlas, generated
// presentation, drafted quote) hangs off this row. Token gates web access to
// /onboard/[token] — no Supabase auth required for prospects.
model Prospect {
  id    String @id @default(cuid())
  email String @unique
  token String @unique

  // Convenience fields lifted out of formData for indexing + display
  contactName  String?
  businessName String?
  role         String?
  website      String?

  status String @default("discovery")
  // discovery | presentation_sent | revising | quote_pending | quote_sent | accepted | ghosted | archived

  // Structured intake answers — keys match the onboarding form spec
  formData Json @default("{}")

  // Uploaded SOPs / docs — [{filename, url, sizeBytes, uploadedAt}]
  sopFiles Json @default("[]")

  // Atlas <-> prospect conversation — [{role, content, ts}]
  chatLog Json @default("[]")

  // Latest generated presentation. `presentationData` holds the structured
  // `ProposalEmailData` JSON Atlas emits (consumed by the Handlebars template
  // and, later, Vera's design-verify pass). `presentationHtml` is the rendered
  // HTML actually emailed to the prospect. Regenerated on each
  // "make changes" loop.
  presentationData        Json?
  presentationHtml        String?   @db.Text
  presentationGeneratedAt DateTime?

  // PRD = internal Product Requirements / agent spec drafted by Atlas after
  // scope approval (status: quote_pending). Kyle reviews in the dashboard,
  // approves to lock the spec the quote is drafted from, and on Client
  // conversion the Agent row gets auto-scaffolded from this. Shape mirrors
  // oracle/templates/prd/types.ts AgentPRDData.
  prdData               Json?
  prdGeneratedAt        DateTime?
  prdApprovedAt         DateTime?
  // PRD-generation retry state. Atlas's PRD synthesis can fail transiently
  // (Anthropic 529, Zod-schema misalignment, network blips). Approve route
  // fires attempt #1; a 15-min cron retries up to 3 more times, then alerts
  // Kyle one-shot via prdGenerationFailedAt.
  prdGenerationAttempts Int       @default(0)
  prdLastAttemptAt      DateTime?
  prdGenerationFailedAt DateTime?

  // Quote: Atlas-drafted, Kyle-reviewed-and-edited, then sent to the prospect.
  // Lifecycle:
  //   status quote_pending → Atlas drafts after PRD approval, quoteDraft set
  //   Kyle edits in dashboard, hits Send → status quote_sent, quoteSentAt set
  //   Prospect clicks Approve on hosted /quotes/[token] page → status accepted,
  //     quoteAcceptedAt set (Phase C: Stripe checkout fires here)
  //   Prospect clicks Deny → status quote_denied, quoteDeniedAt + optional
  //     quoteDeniedReason set
  // Shape of quoteDraft mirrors oracle/templates/quote/types.ts QuoteData.
  quoteDraft        Json?
  quoteSentAt       DateTime?
  quoteAcceptedAt   DateTime?
  quoteDeniedAt     DateTime?
  quoteDeniedReason String?   @db.Text

  // Once accepted + paid, link to the freshly-created Client row.
  convertedClientId String?
  convertedClient   Client? @relation(fields: [convertedClientId], references: [id], onDelete: SetNull)

  // Email-send audit trail for any email Atlas/Vera/etc fire to this prospect
  // (proposal teaser, quote teaser, status updates). Lets us see delivery
  // state in the dashboard and alert on bounces. See `EmailSend` model.
  emailSends EmailSend[]

  // Atlas-on-Fable build runs. Created when the prospect's quote is accepted.
  // 1:N because a rejected build can trigger a fresh one — keep history.
  builds Build[]

  lastActivityAt DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
  @@index([token])
  @@index([lastActivityAt])
  @@index([convertedClientId])
}

// Build = one Atlas-on-Fable orchestration run, fired when a Prospect's quote
// is accepted. Atlas (coordinator) delegates to Vera (QA), Story-writer
// (generates 6-12 dry-run scenarios from the PRD), Builder (drafts the agent
// system prompt + tool selection), and Tester sub-agents (run each scenario
// against the candidate agent in dry-run mode, capturing into DryRunLog rows).
//
// Lifecycle:
//   queued    — row created, Managed Agents session not yet started
//   running   — session live, sub-agents executing
//   completed — all scenarios ran, Vera reviewed, ready for operator approval
//   failed    — session crashed / hit cost cap / cancelled by operator
//
// The candidate Agent is created EARLY (in "pending_approval" + dryRun=true)
// so Tester sub-agents have a real Agent row to run scenarios against. If the
// operator rejects the build, the Agent stays in pending_approval until they
// either re-trigger Fable or hit "Skip Fable, go manual".
model Build {
  id String @id @default(cuid())

  prospectId String
  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  // The candidate agent being built. Nullable because the row is created
  // before the Builder sub-agent has spawned the Agent (a few seconds of
  // window). Set as soon as Builder calls create_agent_row via the MCP.
  agentId String?
  agent   Agent?  @relation(fields: [agentId], references: [id], onDelete: SetNull)

  // Anthropic Managed Agents handles
  managedAgentId String? // /v1/agents id for Atlas (the coordinator agent definition)
  sessionId      String? // /v1/sessions id — the running build session
  environmentId  String? // /v1/environments id — the sandbox

  status String @default("queued")
  // queued | running | completed | failed | cancelled

  // Scenarios Atlas generated via Story-writer. Shape: [{id, label, inboundEmail, expectedOutcome}, ...]
  scenarios Json @default("[]")

  // Vera's per-capture verdicts after the build runs.
  // Shape: [{captureId, scenarioId, verdict: "approve"|"reject", issues: [...]}]
  veraVerdicts Json @default("[]")

  // Running cost counter in cents, summed across all sub-agent token usage in
  // this session. Build is killed if it exceeds budgetCents (env-controlled
  // default $200).
  costCents   Int @default(0)
  budgetCents Int @default(20000)

  failureReason String? @db.Text

  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([prospectId])
  @@index([agentId])
  @@index([status])
  @@index([createdAt])
}

// AgentImprovement = one weekly Atlas-on-Fable self-improvement cycle for an
// active Agent. Atlas reads the agent's recent activity (conversations,
// recommendations, outcomes), proposes a system-prompt edit, runs the edit
// against past dry-run scenarios as a regression sanity-check, and emits a
// proposal for human review. Per Kyle's spec: self-improvement requires
// human-in-the-loop intervention — NO auto-ship, even on 100% regression
// pass. Operator approves/rejects in the dashboard; on approve the Agent
// row's personality/purpose/clientNorthStar fields update.
//
// Lifecycle:
//   pending  — Atlas opened a session, work in progress
//   ready    — Atlas finished + emitted a proposal, awaiting human review
//   shipped  — operator approved; Agent row updated; old values stored
//              in `previousPersonality`/`previousPurpose` so we can revert
//   rejected — operator declined the proposal
//   failed   — Atlas crashed mid-cycle; failureReason set
//
// One row per (agent, week) — the cron skips agents that already have a
// pending or ready row for the current calendar week.
model AgentImprovement {
  id      String @id @default(cuid())
  agentId String
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  // Managed Agents handles
  sessionId     String?
  environmentId String?

  status String @default("pending")
  // pending | ready | shipped | rejected | failed

  // Atlas's proposal — the new draft.
  proposedPersonality String? @db.Text
  proposedPurpose     String? @db.Text
  proposedNorthStar   String? @db.Text
  proposedToolSlugs   Json? // ["string"] — when Atlas suggests adding/removing tools
  rationale           String? @db.Text

  // Snapshot of the prior values (taken at the moment we ship) so we can revert.
  previousPersonality String? @db.Text
  previousPurpose     String? @db.Text
  previousNorthStar   String? @db.Text

  // Regression test results — Atlas re-runs past dry-run scenarios against
  // the proposed prompt. Shape: { scenarioId, baselinePass, proposedPass,
  // delta: "improved" | "regressed" | "neutral", note }
  regressionResults Json @default("[]")

  // Activity signals Atlas used to reach the proposal (saved for operator
  // review so they can sanity-check the diagnosis):
  //   { conversationCount, recommendationCount, approvalRate,
  //     implementationRate, topComplaintThemes: [...] }
  activitySummary Json?

  // Operator decision
  reviewedAt   DateTime?
  reviewedNote String?   @db.Text

  failureReason String? @db.Text

  costCents   Int @default(0)
  budgetCents Int @default(5000) // $50 default — improvements are cheaper than builds

  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([agentId])
  @@index([status])
  @@index([createdAt])
  @@index([agentId, createdAt])
}

model OracleAction {
  id          String  @id @default(cuid())
  actionType  String
  description String  @db.Text
  agentId     String?
  clientId    String?
  status      String  @default("completed")
  result      String? @db.Text

  createdAt DateTime @default(now())

  @@index([actionType])
  @@index([agentId])
  @@index([createdAt])
}

model Lead {
  id       String @id @default(cuid())
  agentId  String
  agent    Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // What the agent sourced. `name` is the headline — a person, company, or
  // property/address depending on the agent's domain.
  name    String
  company String?
  email   String?
  phone   String?

  // Pipeline status. Free-form, but the portal understands these:
  //   new | contacted | replied | qualified | won | lost | archived
  status   String  @default("new")
  source   String? // where it came from, e.g. "CoStar export", "web research"
  valueUsd Int? // estimated deal value in whole US dollars (optional)

  notes String? @db.Text
  // Domain-specific structured fields the agent wants to surface, e.g.
  // { address, capRate, NOI, units, scenario }. Rendered as key/value pairs.
  details Json?

  lastContactedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([agentId])
  @@index([clientId])
  @@index([agentId, status])
  @@index([agentId, createdAt])
}

// ClientDevice — a paired local worker (v1: the "Ambitt Agents" Chrome
// extension) bound to a client. The device authenticates every request with an
// HMAC device token that encodes this row's id (see shared/device-token.ts);
// revocation is the status/revokedAt check done per request. A device belongs
// to the CLIENT and serves every one of that client's agents. This is the
// on-device execution surface that lets an agent work inside the client's own
// logged-in browser session (no credentials stored, no bot-detected cloud
// browser) — see LocalTask.
model ClientDevice {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  status   String  @default("pending") // "pending" | "active" | "revoked"
  label    String? // set by the extension on pair, e.g. "Chrome on macOS"
  platform String? @default("chrome-extension")

  // Pairing handshake: the portal (Supabase-authed) mints a short code; the
  // extension exchanges it for a device token within the expiry window.
  pairingCode      String?   @unique
  pairingExpiresAt DateTime?

  lastSeenAt DateTime? // updated on every poll — powers "online" detection
  createdAt  DateTime  @default(now())
  pairedAt   DateTime?
  revokedAt  DateTime?

  localTasks LocalTask[]

  @@index([clientId, status])
  @@index([pairingCode])
}

// LocalTask — a browse job the platform dispatches to a client's paired device
// to run inside the client's own logged-in browser. The device polls for
// pending tasks, shows the client an allow prompt, drives the tab under the
// platform's step-by-step direction (brain stays on the platform), and posts
// the result back. Credentials NEVER ride in the goal — the device reuses the
// session the client is already signed into.
model LocalTask {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  agentId  String
  agent    Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  deviceId String?
  device   ClientDevice? @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  kind String @default("browse") // "browse" for now

  goal            String  @db.Text
  startingUrl     String?
  allowPromptText String? @db.Text // shown to the client in the per-run allow prompt

  // "pending"   — enqueued, not yet claimed by a device
  // "claimed"   — a device picked it up and is showing the allow prompt
  // "approved"  — client clicked Allow; the device is driving the tab
  // "denied"    — client clicked Not now
  // "succeeded" — finished; result populated
  // "failed"    — errored
  // "cancelled" — cancelled by the platform (timed out / superseded)
  status String @default("pending")

  result     String? @db.Text // final extracted data / summary the agent consumes
  transcript Json? // step-by-step action log for debugging
  error      String? @db.Text

  createdAt  DateTime  @default(now())
  claimedAt  DateTime?
  approvedAt DateTime?
  startedAt  DateTime?
  endedAt    DateTime?
  expiresAt  DateTime? // hard deadline; the poller cancels anything past this

  @@index([clientId, status])
  @@index([deviceId, status])
  @@index([agentId, createdAt])
  @@index([status, createdAt])
}

// Observability for every inbound email Resend delivers to /webhooks/email-inbound.
// One row per webhook, written in a finally so it captures every exit path
// (dropped-no-agent, dropped-unauthorized, 2fa, docs, runtime, error). Lets us
// answer "did the email arrive, where did it drop off, and how fast" without
// guessing — and measures inbound latency.
model InboundEmailLog {
  id          String  @id @default(cuid())
  emailId     String? // Resend email_id (UUID for inbound)
  fromAddr    String?
  toAddr      String? // comma-joined recipients
  subject     String?
  agentId     String? // resolved recipient agent, if any
  clientId    String?
  routingPath String? // "reply" | "direct"
  authResult  String? // "ok" | "rejected:<reason>"
  bodyFetched String? // "ok" | "failed:<status>" | "skipped:had_body" | null (not attempted)
  // "received" (default) then overwritten by the response status:
  // ignored | 2fa_captured | documents_stored | action_processed | replied | error
  disposition String  @default("received")
  errorMsg    String? @db.Text
  ms          Int? // total handler time in milliseconds
  createdAt   DateTime @default(now())

  @@index([agentId, createdAt])
  @@index([disposition, createdAt])
  @@index([createdAt])
}
