generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Client {
  id                    String    @id @default(cuid())
  email                 String    @unique
  contactName           String?
  preferredName         String?                             // what the client wants the agent to call them (e.g. "Kyle" even if contactName is "Kyle Kufuor")
  businessName          String
  industry              String
  businessGoal          String
  website               String?
  brandVoice            String    @db.Text
  preferredChannel      String
  whatsappNumber        String?

  onboardingCompletedAt DateTime?
  northStarMetric       String?
  agentGoal             String?   @db.Text
  createdAt             DateTime  @default(now())

  stripeCustomerId      String    @unique
  billingEmail          String
  billingStatus         String    @default("active")
  pausedAt              DateTime?
  cancelledAt           DateTime?

  // Overage billing — when true, agent keeps working past interactionLimit and
  // we charge overageRateCents per extra interaction at end of month. When
  // false (default), agent hard-stops at the limit.
  overageEnabled        Boolean   @default(false)
  overageRateCents      Int       @default(10) // 10¢/interaction by default ($0.05-0.10 range)

  // 1Password vault UUID scoped to this client. Set by Kyle during onboarding
  // (white-glove, matches the Zoom co-setup). When non-null, the resolveSecret
  // helper validates that any op:// ref's vault matches this UUID before
  // calling 1Password, preventing cross-tenant secret access. Null = no
  // vault yet; any browser task referencing {{secret:op://...}} will fail
  // until Kyle provisions one.
  onepasswordVaultId    String?

  agents                Agent[]
  tasks                 Task[]
  recommendations       Recommendation[]
  outcomes              Outcome[]
  credentials           Credential[]
  conversationMessages  ConversationMessage[]
  suppressions          Suppression[]
  overageEvents         OverageEvent[]
  scheduledEmails       ScheduledEmail[]
  toolRequests          ToolRequest[]
  toolConnectionRequests ToolConnectionRequest[]
  browserSessions       BrowserSession[]
  credentialAccesses    CredentialAccess[]
  prospectsConvertedFrom Prospect[]

  @@index([stripeCustomerId])
  @@index([billingStatus])
}

model Agent {
  id                    String    @id @default(cuid())
  clientId              String
  client                Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  name                  String
  email                 String    @unique
  personality           String    @db.Text
  purpose               String    @db.Text
  agentType             String

  // Platform-level flag — when true, this agent accepts emails from any active
  // Prospect (not just its owner client). Used for Atlas-style onboarding
  // agents that need to talk to non-clients. See inbound webhook auth in
  // oracle/index.ts.
  acceptFromProspects   Boolean   @default(false)

  tools                 String[]
  schedule              String
  autonomyLevel         String    @default("supervised")       // "supervised" | "autonomous" — supervised is default (plan-then-approve); client toggles to autonomous once they trust the agent. Legacy values "advisory" / "copilot" are migrated on-read in scaffold.ts.
  timezone              String    @default("America/New_York") // IANA tz — governs cron firing + polite hours
  deliveryFormat        String    @default("email_summary")    // "email_summary" | "email_with_attachments" | "email_plus_sheet"
  tone                  String    @default("conversational")   // "formal" | "conversational" | "brief" — client-configurable voice register
  emailFrequency        String    @default("immediate")        // "immediate" | "daily_digest" | "weekly_digest" — when non-immediate, runs queue to ScheduledEmail (kind="digest_pending") and the hourly processDueDigests cron rolls them up
  // Digest cadence (ignored when emailFrequency="immediate"). Client-configurable via portal; defaults are 8am agent-timezone / Monday.
  digestHour            Int       @default(8)                  // 0-23 in agent timezone
  digestDayOfWeek       Int       @default(1)                  // 0=Sun..6=Sat, used only for weekly_digest
  lastDigestSentAt      DateTime?                              // prevents double-send within a period
  clientNorthStar       String?

  primaryModel          String    @default("claude-sonnet-4-6")
  analyticsModel        String    @default("gemini")
  creativeModel         String    @default("gpt-4o")

  status                String    @default("pending_approval")
  approvedAt            DateTime?
  lastRunAt             DateTime?
  nextScheduledRun      DateTime?

  stripeSubscriptionId  String?
  setupFeeInvoiceId     String?
  monthlyRetainerCents  Int
  setupFeeCents         Int
  historyTier           String    @default("standard")

  // Pricing tier
  pricingTier           String    @default("starter") // "starter" | "growth" | "scale" | "enterprise"

  // Interaction tracking
  interactionCount      Int       @default(0)         // current billing cycle
  interactionLimit      Int       @default(1000)      // per tier: 1000/3000/-1(unlimited)
  overageCount          Int       @default(0)         // extra interactions past the limit (only if client opted into overage)
  interactionResetAt    DateTime?                     // next reset date (monthly)

  // Budget enforcement
  budgetMonthlyCents    Int       @default(5000) // $50 default
  budgetWarningAt       DateTime? // when 80% threshold was hit
  budgetPausedAt        DateTime? // when 100% threshold paused the agent

  clientMemoryObject    String    @db.Text
  lastMemoryUpdateAt    DateTime?

  totalTasksCompleted   Int       @default(0)
  totalRecommendations  Int       @default(0)
  approvalRate          Float     @default(0)
  implementationRate    Float     @default(0)

  tasks                 Task[]
  recommendations       Recommendation[]
  outcomes              Outcome[]
  conversationMessages  ConversationMessage[]
  performanceSignals    PerformanceSignal[]
  apiUsage              ApiUsage[]
  suppressions          Suppression[]
  overageEvents         OverageEvent[]
  scheduledEmails       ScheduledEmail[]
  toolRequests          ToolRequest[]
  toolConnectionRequests ToolConnectionRequest[]
  browserSessions       BrowserSession[]
  credentialAccesses    CredentialAccess[]

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([clientId])
  @@index([clientId, agentType])
  @@index([status])
  @@index([agentType])
}

model Task {
  id                    String    @id @default(cuid())
  agentId               String
  agent                 Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  clientId              String
  client                Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  taskType              String
  description           String    @db.Text

  status                String    @default("pending")
  executedAt            DateTime?
  completedAt           DateTime?
  errorMessage          String?   @db.Text
  retryCount            Int       @default(0)

  rawOutput             String    @db.Text
  emailSentAt           DateTime?
  whatsappSentAt        DateTime?

  recommendations       Recommendation[]

  createdAt             DateTime  @default(now())

  @@index([agentId])
  @@index([clientId])
  @@index([status])
  @@index([taskType])
}

model Recommendation {
  id                    String    @id @default(cuid())
  agentId               String
  agent                 Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  clientId              String
  client                Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  taskId                String?
  task                  Task?     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  title                 String
  description           String    @db.Text
  actionItems           String[]
  reasoning             String?   @db.Text

  expectedMetric        String
  baselineValue         Float
  expectedDirection     String
  expectedChangePct     Float?

  implementationMode    String    @default("advisory")
  autonomouslyExecuted  Boolean   @default(false)
  autonomousActionLog   String?   @db.Text

  // Email template context
  emailType             String?
  approveActionId       String?   @unique
  status                String    @default("pending")

  clientAction          String    @default("pending")
  clientActionAt        DateTime?
  clientNotes           String?   @db.Text

  verificationScheduled DateTime?
  verifiedAt            DateTime?
  verificationMethod    String?
  verificationResult    Boolean?
  verificationNotes     String?   @db.Text

  resolvedAt            DateTime?

  outcomes              Outcome[]

  sentAt                DateTime  @default(now())

  @@index([agentId])
  @@index([clientId])
  @@index([clientAction])
  @@index([expectedMetric])
  @@index([implementationMode])
  @@index([approveActionId])
  @@index([status])
}

model Outcome {
  id                    String    @id @default(cuid())
  agentId               String
  agent                 Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  clientId              String
  client                Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  recommendationId      String
  recommendation        Recommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)

  metric                String
  baselineValue         Float
  measuredValue         Float
  changeAmount          Float
  changePercent         Float

  measuredAt            DateTime
  measurementWindow     String
  measurementMethod     String
  toolUsed              String?
  rawData               String?   @db.Text

  confidenceLevel       String    @default("medium")
  implementationVerified Boolean  @default(false)
  notes                 String?   @db.Text

  createdAt             DateTime  @default(now())

  @@index([recommendationId])
  @@index([metric])
  @@index([measurementWindow])
  @@index([agentId])
  @@index([clientId])
}

model ConversationMessage {
  id                    String    @id @default(cuid())
  agentId               String
  agent                 Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  clientId              String
  client                Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  role                  String
  content               String    @db.Text
  channel               String

  threadId              String
  inReplyTo             String?

  archivedAt            DateTime?

  createdAt             DateTime  @default(now())

  @@index([agentId])
  @@index([clientId])
  @@index([threadId])
  @@index([archivedAt])
}

model PerformanceSignal {
  id                    String    @id @default(cuid())
  agentId               String
  agent                 Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)

  signalType            String
  outputSummary         String    @db.Text
  clientAction          String    @db.Text

  agentType             String
  anonymized            Boolean   @default(true)

  createdAt             DateTime  @default(now())

  @@index([agentId])
  @@index([agentType])
  @@index([signalType])
}

model Credential {
  id                    String    @id @default(cuid())
  clientId              String
  client                Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  toolName              String
  oauthToken            String?   @db.Text
  apiKey                String?   @db.Text
  refreshToken          String?   @db.Text
  expiresAt             DateTime?

  connectedAt           DateTime  @default(now())
  lastUsedAt            DateTime?
  status                String    @default("active")

  @@unique([clientId, toolName])
  @@index([clientId])
  @@index([status])
}

model ApiUsage {
  id                    String    @id @default(cuid())
  agentId               String
  agent                 Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)

  model                 String
  inputTokens           Int                             // uncached input tokens only
  outputTokens          Int
  totalTokens           Int
  cacheCreationTokens   Int       @default(0)           // billed at 1.25× base input rate
  cacheReadTokens       Int       @default(0)           // billed at 0.10× base input rate
  toolErrorCount        Int       @default(0)           // failed tool calls during this run — used for agent error rate
  isPrimaryRun          Boolean   @default(true)        // false on secondary rows from multi-model runs (e.g. Haiku row when Sonnet also wrote) so run-level counts don't double
  costInCents           Int                             // authoritative — computed at write time

  taskType              String
  taskId                String?

  createdAt             DateTime  @default(now())

  @@index([agentId])
  @@index([model])
  @@index([createdAt])
}

model OverageEvent {
  id                    String    @id @default(cuid())
  clientId              String
  client                Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  agentId               String
  agent                 Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)

  unitCostCents         Int                               // snapshot of overageRateCents at time of event
  billingCycleMonth     String                            // "YYYY-MM" for end-of-month aggregation
  invoicedAt            DateTime?                         // when this was rolled up into a Stripe invoice
  createdAt             DateTime  @default(now())

  @@index([clientId, billingCycleMonth])
  @@index([agentId])
  @@index([invoicedAt])
}

// ScheduledEmail — onboarding-checkpoint emails enqueued on agent approval
// (T+3 check-in, T+7 capability highlight, T+14 feedback + 2nd-agent pitch).
// A daily cron in oracle/scheduler.ts picks up rows where status=pending and
// scheduledAt <= now() and fires them through the email router.
model ScheduledEmail {
  id                    String    @id @default(cuid())
  agentId               String
  agent                 Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  clientId              String
  client                Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  kind                  String                                // "checkin_3day" | "highlight_7day" | "feedback_14day" | "digest_pending" | "digest"
  scheduledAt           DateTime
  status                String    @default("pending")         // pending | sent | cancelled | failed
  sentAt                DateTime?
  errorMessage          String?   @db.Text

  // Used by kind="digest_pending": JSON snapshot of one queued run
  // ({ response, toolsUsed, attachmentMeta, recommendations, ranAt }). Rolled up
  // by processDueDigests cron into a single kind="digest" email. Null for
  // checkpoint rows.
  payload               String?   @db.Text

  createdAt             DateTime  @default(now())

  @@index([status, scheduledAt])
  @@index([agentId])
  @@index([clientId])
  @@index([agentId, kind, status])
}

model StripeEvent {
  id                    String    @id
  type                  String
  data                  String    @db.Text
  processed             Boolean   @default(false)
  processedAt           DateTime?

  createdAt             DateTime  @default(now())

  @@index([type])
  @@index([processed])
}

model Suppression {
  id                    String    @id @default(cuid())
  agentId               String
  agent                 Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  clientId              String
  client                Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // What was suppressed
  findingKey            String    // e.g. "activation_broken", "low_traffic", "signup_drop"
  findingDescription    String    @db.Text
  metricName            String    // the metric this finding relates to
  metricValueAtSend     Float     // the value when the finding was last sent

  // When to unsuppress
  cooldownDays          Int       @default(7)   // minimum days before resending
  changeThresholdPct    Float     @default(10)  // resend if metric changes by this %

  // Tracking
  lastSentAt            DateTime
  suppressUntil         DateTime  // computed: lastSentAt + cooldownDays
  sendCount             Int       @default(1)   // how many times this finding has been sent

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([agentId, clientId, findingKey])
  @@index([agentId])
  @@index([clientId])
  @@index([suppressUntil])
}

// ToolRequest — client asks for a tool that isn't in Composio's OAuth catalog.
// Submitted from the portal's agent detail page. Kyle gets a WhatsApp ping on
// every new row; he resolves manually (white-glove path). Lean by design — no
// URL or category fields; Kyle asks for more context in the follow-up.
model ToolRequest {
  id                    String    @id @default(cuid())
  clientId              String
  client                Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  agentId               String
  agent                 Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)

  toolName              String
  reason                String    @db.Text

  status                String    @default("pending") // "pending" | "resolved" | "dismissed"
  resolvedAt            DateTime?
  resolvedNote          String?   @db.Text

  createdAt             DateTime  @default(now())

  @@index([clientId, status])
  @@index([agentId])
  @@index([createdAt])
}

// ToolConnectionRequest — agent realized mid-run it needs an OAuth tool it
// doesn't have, invoked the request_tool_connection platform tool, and we've
// emailed the client a Composio OAuth link. Distinct from ToolRequest (which
// is the portal white-glove path fulfilled by Kyle). De-dup window: don't
// re-email the same (clientId, appName) if an open row exists from the last
// 24h — see shared/runtime/tools/request-tool-connection.ts.
model ToolConnectionRequest {
  id                    String    @id @default(cuid())
  clientId              String
  client                Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  agentId               String
  agent                 Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)

  appName               String    // Composio app slug, e.g. "gmail", "googlecalendar"
  reason                String    @db.Text // agent-authored explanation of why it needs this, surfaced in the email

  composioConnectionId  String?   // returned by initiateOAuthConnection(); null until we've called Composio
  redirectUrl           String?   @db.Text // the OAuth URL the client clicks; null until emailed

  status                String    @default("pending") // "pending" | "emailed" | "connected" | "expired" | "declined"
  emailSentAt           DateTime?
  connectedAt           DateTime?

  createdAt             DateTime  @default(now())

  @@index([clientId, appName, status])
  @@index([agentId])
  @@index([composioConnectionId])
  @@index([createdAt])
}

// BrowserSession — audit trail for one Stagehand/Browserbase session run by
// the `browse` platform tool. Written on open, updated on close. Transcript
// is a short summary of what Claude saw/did (not the full page HTML). Use
// for debugging + cost visibility. browserbaseSessionId lets us jump to the
// Browserbase dashboard for the same session when triaging a failure.
model BrowserSession {
  id                    String    @id @default(cuid())
  agentId               String
  agent                 Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  clientId              String
  client                Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  goal                  String    @db.Text
  startingUrl           String?
  browserbaseSessionId  String?   // set once the session starts

  startedAt             DateTime  @default(now())
  endedAt               DateTime?
  durationMs            Int?

  status                String    @default("running") // "running" | "success" | "failed" | "timeout"
  resultSummary         String?   @db.Text // short summary of what the agent did / extracted
  errorMessage          String?   @db.Text

  @@index([agentId, startedAt])
  @@index([clientId, startedAt])
  @@index([status])
  @@index([browserbaseSessionId])
}

// CredentialAccess — audit row written every time resolveSecret() returns a
// value to a caller. Powers the per-row "last accessed Apr 22" audit trail
// on the portal Tools page and underwrites the trust contract ("we can
// only ask 1Password to use them; here's exactly when we did"). NEVER
// stores the secret value itself — only metadata.
model CredentialAccess {
  id          String    @id @default(cuid())
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  agentId     String?
  agent       Agent?    @relation(fields: [agentId], references: [id], onDelete: SetNull)

  vaultName   String    // Client.onepasswordVaultId at time of access
  itemTitle   String    // 1P item title (e.g. "LinkedIn")
  field       String    // field name within the item (e.g. "password")

  accessedAt  DateTime  @default(now())

  @@index([clientId, vaultName, itemTitle, accessedAt])
  @@index([agentId, accessedAt])
  @@index([accessedAt])
}

// Prospect — a lead going through the onboarding flow with Atlas. Lives
// separately from Client until the deal closes (quote accepted + paid), at
// which point a Client row is created and Prospect.convertedClientId is set.
// All intake state (form answers, SOPs, chat with Atlas, generated
// presentation, drafted quote) hangs off this row. Token gates web access to
// /onboard/[token] — no Supabase auth required for prospects.
model Prospect {
  id                       String    @id @default(cuid())
  email                    String    @unique
  token                    String    @unique

  // Convenience fields lifted out of formData for indexing + display
  contactName              String?
  businessName             String?
  role                     String?
  website                  String?

  status                   String    @default("discovery")
  // discovery | presentation_sent | revising | quote_pending | quote_sent | accepted | ghosted | archived

  // Structured intake answers — keys match the onboarding form spec
  formData                 Json      @default("{}")

  // Uploaded SOPs / docs — [{filename, url, sizeBytes, uploadedAt}]
  sopFiles                 Json      @default("[]")

  // Atlas <-> prospect conversation — [{role, content, ts}]
  chatLog                  Json      @default("[]")

  // Latest generated presentation. `presentationData` holds the structured
  // `ProposalEmailData` JSON Atlas emits (consumed by the Handlebars template
  // and, later, Vera's design-verify pass). `presentationHtml` is the rendered
  // HTML actually emailed to the prospect. Regenerated on each
  // "make changes" loop.
  presentationData         Json?
  presentationHtml         String?   @db.Text
  presentationGeneratedAt  DateTime?

  // PRD = internal Product Requirements / agent spec drafted by Atlas after
  // scope approval (status: quote_pending). Kyle reviews in the dashboard,
  // approves to lock the spec the quote is drafted from, and on Client
  // conversion the Agent row gets auto-scaffolded from this. Shape mirrors
  // oracle/templates/prd/types.ts AgentPRDData.
  prdData                  Json?
  prdGeneratedAt           DateTime?
  prdApprovedAt            DateTime?
  // PRD-generation retry state. Atlas's PRD synthesis can fail transiently
  // (Anthropic 529, Zod-schema misalignment, network blips). Approve route
  // fires attempt #1; a 15-min cron retries up to 3 more times, then alerts
  // Kyle one-shot via prdGenerationFailedAt.
  prdGenerationAttempts    Int        @default(0)
  prdLastAttemptAt         DateTime?
  prdGenerationFailedAt    DateTime?

  // Quote: Atlas-drafted, Kyle-reviewed-and-edited, then sent to the prospect.
  // Lifecycle:
  //   status quote_pending → Atlas drafts after PRD approval, quoteDraft set
  //   Kyle edits in dashboard, hits Send → status quote_sent, quoteSentAt set
  //   Prospect clicks Approve on hosted /quotes/[token] page → status accepted,
  //     quoteAcceptedAt set (Phase C: Stripe checkout fires here)
  //   Prospect clicks Deny → status quote_denied, quoteDeniedAt + optional
  //     quoteDeniedReason set
  // Shape of quoteDraft mirrors oracle/templates/quote/types.ts QuoteData.
  quoteDraft               Json?
  quoteSentAt              DateTime?
  quoteAcceptedAt          DateTime?
  quoteDeniedAt            DateTime?
  quoteDeniedReason        String?    @db.Text

  // Once accepted + paid, link to the freshly-created Client row.
  convertedClientId        String?
  convertedClient          Client?   @relation(fields: [convertedClientId], references: [id], onDelete: SetNull)

  lastActivityAt           DateTime  @default(now())
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  @@index([status])
  @@index([token])
  @@index([lastActivityAt])
  @@index([convertedClientId])
}

model OracleAction {
  id                    String    @id @default(cuid())
  actionType            String
  description           String    @db.Text
  agentId               String?
  clientId              String?
  status                String    @default("completed")
  result                String?   @db.Text

  createdAt             DateTime  @default(now())

  @@index([actionType])
  @@index([agentId])
  @@index([createdAt])
}
