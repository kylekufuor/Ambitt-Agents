{
  "manifest_version": 3,
  "name": "Ambitt Agents",
  "version": "0.1.0",
  "description": "Lets your Ambitt agent do work inside your own logged-in browser, with your permission each time. No passwords stored.",
  "permissions": ["storage", "alarms", "tabs", "scripting"],
  "host_permissions": ["https://oracle-production-c0ff.up.railway.app/*"],
  "optional_host_permissions": [
    "https://*.costar.com/*",
    "https://*.costargroup.com/*",
    "https://*.crexi.com/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "Ambitt Agents",
    "default_popup": "popup.html"
  }
}
