# Ambitt Agents — Environment Variables
# Copy to .env and fill in values

# Database (Supabase)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# AI Models
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# Email (Resend)
RESEND_API_KEY=
EMAIL_DOMAIN=ambitt.agency

# WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# Billing (Stripe)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Kyle
KYLE_WHATSAPP_NUMBER=
KYLE_EMAIL=

# Security
APP_ENCRYPTION_KEY=

# Composio (850+ tool gateway)
COMPOSIO_API_KEY=

# Platform Tools (free tiers available)
GOOGLE_API_KEY=

# Infrastructure
ORACLE_URL=http://localhost:3000
CALENDLY_URL=

# Runtime
NODE_ENV=development
PORT=3000
